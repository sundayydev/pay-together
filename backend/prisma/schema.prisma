// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "postgresql"
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum SettlementStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOMO
}

// Trạng thái quyết toán của từng khoản chi
enum ExpenseStatus {
  PENDING   // Chưa quyết toán (Hiển thị màu cam/đỏ trên lịch và cho phép chọn)
  SETTLED   // Đã quyết toán xong (Hiển thị màu xanh và KHÔNG được chọn lại)
}

// Trạng thái của phiên quyết toán theo khoảng ngày
enum SettlementSessionStatus {
  PENDING   // Đang chờ tất cả thành viên hoàn thành chuyển khoản nợ
  COMPLETED // Tất cả thành viên đã thanh toán xong nợ của khoảng ngày đó
}

// 1. Bảng Người Dùng
model User {
  id               BigInt            @id @default(autoincrement())
  phoneNumber      String            @unique
  passwordHash     String
  name             String
  avatarUrl        String?
  momoPhone        String?
  
  bankCode         String?
  bankAccount      String?
  bankAccountName  String?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?         // Soft Delete

  // Quan hệ (Relations)
  createdGroups    Group[]           @relation("GroupCreator")
  groupMemberships GroupMember[]
  paidExpenses     Expense[]         @relation("ExpensePayer")
  loggedExpenses   Expense[]         @relation("ExpenseLogger")
  expenseSplits    ExpenseSplit[]
  sentSettlements  Settlement[]      @relation("SettlementPayer")
  receivedSettlements Settlement[]   @relation("SettlementReceiver")
  createdSessions  SettlementSession[] @relation("SessionCreator")
  refreshTokens    RefreshToken[]
}

// 3. Bảng Nhóm
model Group {
  id           BigInt              @id @default(autoincrement())
  name         String
  description  String?
  inviteCode   String              @unique
  inviteActive Boolean             @default(true)
  createdById  BigInt
  creator      User                @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?           // Soft Delete

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  sessions     SettlementSession[]
}

// 4. Bảng Thành Viên Nhóm (Trung gian)
model GroupMember {
  id       BigInt    @id @default(autoincrement())
  groupId  BigInt
  group    Group     @relation(fields: [groupId], references: [id])
  userId   BigInt
  user     User      @relation(fields: [userId], references: [id])
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  deletedAt DateTime? // Soft Delete

  @@unique([groupId, userId])
}

// 5. Bảng Khoản Chi Tiêu
model Expense {
  id                  BigInt             @id @default(autoincrement())
  groupId             BigInt
  group               Group              @relation(fields: [groupId], references: [id])
  paidById            BigInt
  paidBy              User               @relation("ExpensePayer", fields: [paidById], references: [id])
  amount              Decimal            @db.Decimal(12, 2)
  description         String
  expenseDate         DateTime           @default(now())
  createdById         BigInt
  createdBy           User               @relation("ExpenseLogger", fields: [createdById], references: [id])
  status              ExpenseStatus      @default(PENDING) // Trạng thái quyết toán của khoản chi
  settlementSessionId BigInt?            // Thuộc phiên quyết toán nào
  settlementSession   SettlementSession? @relation(fields: [settlementSessionId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?          // Soft Delete

  splits              ExpenseSplit[]

  @@index([groupId])
  @@index([paidById])
}

// 6. Bảng Phân Bổ Khoản Chi
model ExpenseSplit {
  id        BigInt    @id @default(autoincrement())
  expenseId BigInt
  expense   Expense   @relation(fields: [expenseId], references: [id])
  userId    BigInt
  user      User      @relation(fields: [userId], references: [id])
  amount    Decimal   @db.Decimal(12, 2)
  createdAt DateTime  @default(now())
  deletedAt DateTime? // Soft Delete

  @@unique([expenseId, userId])
}

// 7. Bảng Quyết Toán Thanh Toán Công Nợ (Chuyển khoản thực tế)
model Settlement {
  id                         BigInt             @id @default(autoincrement())
  groupId                    BigInt
  group                      Group              @relation(fields: [groupId], references: [id])
  payerId                    BigInt
  payer                      User               @relation("SettlementPayer", fields: [payerId], references: [id])
  receiverId                 BigInt
  receiver                   User               @relation("SettlementReceiver", fields: [receiverId], references: [id])
  amount                     Decimal            @db.Decimal(12, 2)
  
  paymentMethod              PaymentMethod      @default(BANK_TRANSFER)
  status                     SettlementStatus   @default(PENDING)
  paymentGatewayTransactionId String?            @unique
  paymentLink                String?
  description                String?
  settlementSessionId        BigInt?            // Liên kết với phiên quyết toán
  settlementSession          SettlementSession? @relation(fields: [settlementSessionId], references: [id])
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  deletedAt                  DateTime?          // Soft Delete

  @@index([groupId])
  @@index([payerId])
  @@index([receiverId])
}

// 8. Bảng Phiên Quyết Toán (Theo khoảng ngày)
model SettlementSession {
  id           BigInt                  @id @default(autoincrement())
  groupId      BigInt
  group        Group                   @relation(fields: [groupId], references: [id])
  startDate    DateTime                // Ngày bắt đầu khoảng quyết toán
  endDate      DateTime                // Ngày kết thúc khoảng quyết toán
  status       SettlementSessionStatus @default(PENDING)
  createdById  BigInt
  creator      User                    @relation("SessionCreator", fields: [createdById], references: [id])
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  deletedAt    DateTime?               // Soft Delete

  expenses     Expense[]               // Các khoản chi thuộc phiên chốt này
  settlements  Settlement[]

  @@index([groupId])
}

// 9. Bảng Refresh Token (Chuẩn OIDC/OAuth2)
model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  token     String    @unique
  userId    BigInt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}